<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =========================
         SEQUENCE
    ========================== -->
    <record id="seq_customer_ref" model="ir.sequence">
        <field name="name">Customer Reference</field>
        <field name="code">customer.ref</field>
        <field name="prefix">CUST-</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>


    <!-- =========================
         PARTNER FORM
    ========================== -->
    <record id="view_partner_form_customer_ref" model="ir.ui.view">
        <field name="name">res.partner.form.customer.ref</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='category_id']" position="after">
                <field name="customer_ref" readonly="1"/>
            </xpath>

        </field>
    </record>


    <!-- =========================
         SALE ORDER
    ========================== -->
    <record id="sale_order_form_inherit_customer_ref" model="ir.ui.view">
        <field name="name">sale.order.customer.ref</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="customer_ref" readonly="1"/>
            </xpath>

        </field>
    </record>


    <!-- =========================
         MRP PRODUCTION
    ========================== -->
    <record id="mrp_production_form_inherit_customer_ref" model="ir.ui.view">
        <field name="name">mrp.production.customer.ref</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='origin']" position="after">
                <field name="customer_ref" readonly="1"/>
            </xpath>

        </field>
    </record>

</odoo>