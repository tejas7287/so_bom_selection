<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-inherit="mrp_workorder.MrpDisplayMenuDialog"
       t-inherit-mode="extension">

        <xpath expr="//div[@class='row px-2']" position="inside">
            <div class="col-12 p-1">
                <button
                    class="d-flex flex-column gap-1 btn btn-primary fs-3 w-100 h-100 py-3"
                    t-on-click="() => this.callAction('action_open_barcode_controller')">

                    <i class="fa fa-barcode"/>
                    Print Barcode

                </button>
            </div>
        </xpath>

    </t>

</templates>





